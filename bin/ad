      chomp($ssiz=<$ohnd>);my $olin='';
      while(defined($olin=<$ohnd>)){chomp($olin); #say "sctn:$sctn ssiz:$ssiz olin:$olin"; # this say was just for debugging file loading B4 Simp stRted;
        if (   $sctn==     1 ){if($ssiz){
            if($olin=~ /^\d+\s+\d+\s+\d+\s+\d+\s.+$/    ){push(@linz,$olin);}elsif($olin=~ /^\d+$/){$ssiz=$olin;$sctn++;}}else{$ssiz=$olin;$sctn++;}
        }elsif($sctn==     2 ){if($ssiz){
            if($olin=~ /^\d+\s+\d+\s+\d+\s+\d+$/        ){push(@rctz,$olin);}elsif($olin=~ /^\d+$/){$ssiz=$olin;$sctn++;}}else{$ssiz=$olin;$sctn++;}
        }elsif($sctn==     3 ){if($ssiz){
            if($olin=~ /^\d+\s+\d+\s+\d+\s+\d+$/        ){push(@elpz,$olin);}elsif($olin=~ /^\d+$/){$ssiz=$olin;$sctn++;}}else{$ssiz=$olin;$sctn++;}
        }elsif($sctn==     4 ){if($ssiz){
            if($olin=~ /^\d+\s+\d+\s+[hvud]\s+\d+\s.*$/ ){push(@txtz,$olin);}else                  {$ssiz=$olin;$sctn++;}}}
      } $lflg=1 ; # loaded-file flag set because here I should load existing rEadable file into arrayz && call indexed Draw() subz on thM;
                                close(  $ohnd        ) or die "!*EROR*! Could not close ofil:$_ after loading!";
    }   else          {$ofil=$_;}} # non-help or include param doesn't exist or isn't rEadable in filesys but use as destin8ion sAvfIl anywAy (hOp wrItabl);
my  $simp=tie(@text,'Curses::Simp'            );
          tie(@fclr,'Curses::Simp::FClr',$simp);$simp->CVis(1);my($cy,$cx)=(0,0);my $ht=$simp->Hite(); # y,x for Begin,Cursor,End;
          tie(@bclr,'Curses::Simp::BClr',$simp);$simp->Move(      $cy,$cx);      my $wd=$simp->Widt();$simp->AuDr(0);
for(0..$ht-1){push(@text,' ' x $wd); # abov toggle off AutoDrawFlag to dodge flicker of push redrawing at each empty line (2turnbakon aftr);
              push(@fclr,'W' x $wd);} $simp->AuDr(1); # init blank solid screen of spaces all with bright White color aw8ing text;
if   ($lflg){ # only if already loaded input d8a file above (hopefully successfully), then try to Draw all  ;
